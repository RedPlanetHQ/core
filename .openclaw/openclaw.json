{
  "agent": {
    "model": "ollama/qwen3:32b",
    "maxSteps": 100,
    "temperature": 0.7,
    "_comment": "100% LOKAL — Kein API Key noetig, keine Kosten, alles Open Source"
  },
  "providers": {
    "ollama": {
      "baseURL": "http://localhost:11434",
      "_models": {
        "primary": "qwen3:32b (Reasoning + General — 20GB RAM)",
        "coding": "qwen3-coder (Code-Generierung — 20GB RAM)",
        "reasoning": "deepseek-r1:32b (Deep Thinking — 20GB RAM)",
        "fast": "qwen3:8b (Schnelle Antworten — 5GB RAM)",
        "multimodal": "llama4 (Bilder + Text — 15GB RAM)"
      }
    }
  },
  "browser": {
    "enabled": true,
    "defaultProfile": "openclaw",
    "headless": false,
    "noSandbox": false,
    "attachOnly": false,
    "color": "#FF4500",
    "remoteCdpTimeoutMs": 1500,
    "remoteCdpHandshakeTimeoutMs": 3000,
    "evaluateEnabled": true,
    "snapshotDefaults": {
      "mode": "efficient"
    },
    "ssrfPolicy": {
      "dangerouslyAllowPrivateNetwork": true
    },
    "profiles": {
      "openclaw": {
        "cdpPort": 18800,
        "color": "#FF4500"
      },
      "work": {
        "cdpPort": 18801,
        "color": "#0066CC"
      },
      "chrome": {
        "cdpUrl": "http://127.0.0.1:18792",
        "color": "#4285F4"
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "adminId": "8531161985",
      "activation": "always",
      "forumTopics": true
    }
  },
  "gateway": {
    "port": 18789
  },
  "memory": {
    "enabled": true,
    "maxEntries": 10000,
    "retentionDays": 30
  },
  "skills": {
    "entries": {
      "toggle-context": { "enabled": true },
      "pi-coder": { "enabled": true },
      "meta-ads": { "enabled": true },
      "trading-monitor": { "enabled": true },
      "content-engine": { "enabled": true },
      "seo-ranker": { "enabled": true }
    }
  },
  "security": {
    "scanBeforeInstall": true,
    "auditTrail": "clawprint"
  }
}
