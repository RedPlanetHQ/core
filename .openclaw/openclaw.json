{
  "agent": {
    "model": "ollama/glm4:9b-chat",
    "maxSteps": 100,
    "temperature": 0.7
  },
  "providers": {
    "ollama": {
      "baseURL": "http://localhost:11434"
    }
  },
  "browser": {
    "enabled": true,
    "defaultProfile": "openclaw",
    "headless": false,
    "noSandbox": false,
    "attachOnly": false,
    "color": "#FF4500",
    "remoteCdpTimeoutMs": 1500,
    "remoteCdpHandshakeTimeoutMs": 3000,
    "evaluateEnabled": true,
    "snapshotDefaults": {
      "mode": "efficient"
    },
    "ssrfPolicy": {
      "dangerouslyAllowPrivateNetwork": true
    },
    "profiles": {
      "openclaw": {
        "cdpPort": 18800,
        "color": "#FF4500"
      },
      "work": {
        "cdpPort": 18801,
        "color": "#0066CC"
      },
      "chrome": {
        "cdpUrl": "http://127.0.0.1:18792",
        "color": "#4285F4"
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "adminId": "8531161985",
      "activation": "always",
      "forumTopics": true
    }
  },
  "gateway": {
    "port": 18789
  },
  "memory": {
    "enabled": true,
    "maxEntries": 10000,
    "retentionDays": 30
  },
  "skills": {
    "entries": {
      "toggle-context": { "enabled": true },
      "pi-coder": { "enabled": true },
      "meta-ads": { "enabled": true },
      "trading-monitor": { "enabled": true },
      "content-engine": { "enabled": true },
      "seo-ranker": { "enabled": true }
    }
  },
  "security": {
    "scanBeforeInstall": true,
    "auditTrail": "clawprint"
  }
}
