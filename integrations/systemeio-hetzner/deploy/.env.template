# ============================================================
# KI-POWER DIGITAL FAST FOOD SYSTEM - Server Konfiguration
# ============================================================
# Fuelle diese Datei aus und speichere sie als .env
# ============================================================

# --- Deine API Keys ---
# Systeme.io: Dashboard → Settings → API Keys → Create
SYSTEME_API_KEY=

# Hetzner Cloud: https://console.hetzner.cloud → Security → API Tokens → Generate
HETZNER_API_TOKEN=

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- CORE App Konfiguration ---
VERSION=0.4.0
NODE_ENV=production

# Datenbank (wird automatisch konfiguriert)
POSTGRES_USER=kipower
POSTGRES_PASSWORD=WIRD_AUTOMATISCH_GENERIERT
POSTGRES_DB=core
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=core
DIRECT_URL=${DATABASE_URL}

# App URLs (wird automatisch mit Server-IP gesetzt)
LOGIN_ORIGIN=http://localhost:3033
APP_ORIGIN=http://localhost:3033

# Security (wird automatisch generiert)
SESSION_SECRET=WIRD_AUTOMATISCH_GENERIERT
ENCRYPTION_KEY=WIRD_AUTOMATISCH_GENERIERT
MAGIC_LINK_SECRET=WIRD_AUTOMATISCH_GENERIERT

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TLS_DISABLED=true

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=WIRD_AUTOMATISCH_GENERIERT
NEO4J_AUTH=neo4j/WIRD_AUTOMATISCH_GENERIERT

# Auth
ENABLE_EMAIL_LOGIN=true
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# AI Model
MODEL=gpt-4.1-2025-04-14
EMBEDDING_MODEL=text-embedding-3-small

# Reranking
RERANK_PROVIDER=none

# Queue
QUEUE_PROVIDER=bullmq

# Optional: Domain fuer SSL (ohne https://)
# DOMAIN=ki-power.deine-domain.de
