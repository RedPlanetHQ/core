// ---------------------------------------------------------------------------
// LLM Providers & Models
// ---------------------------------------------------------------------------

model LLMProvider {
  id          String     @id @default(uuid())
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String // "OpenAI", "Anthropic", "Google", "Ollama"
  type        String // "openai", "anthropic", "google", "ollama"
  config      Json       @default("{}")
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  models      LLMModel[]

  @@index([workspaceId])
  @@index([type])
}

model LLMModel {
  id            String      @id @default(uuid())
  providerId    String
  provider      LLMProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  modelId       String // "gpt-5-2025-08-07"
  label         String // "GPT-5"
  complexity    String // "high", "medium", "low"
  supportsBatch Boolean     @default(true)
  isEnabled     Boolean     @default(true)
  isDeprecated  Boolean     @default(false)
  capabilities  String[] // ["chat", "structured", "reasoning"] or ["embedding"]
  dimensions    Int? // For embedding models (e.g., 1024, 1536, 3072)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([providerId])
  @@index([complexity])
}

// ---------------------------------------------------------------------------
// Coding Sessions
// ---------------------------------------------------------------------------

model CodingSession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  externalSessionId String?
  agent             String
  prompt            String?
  dir               String?
  worktreePath      String?
  worktreeBranch    String?

  task   Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String?

  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  conversationId String?

  gateway   Gateway? @relation(fields: [gatewayId], references: [id], onDelete: SetNull)
  gatewayId String?

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  userId      String

  @@index([taskId])
  @@index([workspaceId])
  @@index([conversationId])
  @@index([gatewayId])
}

/// A task's claim on a gateway-side browser session. The "lock" is implicit:
/// `(gatewayId, sessionName)` is considered locked if any BrowserSession row
/// exists for that pair whose owning Task is in a non-terminal status (i.e.
/// not `Done`). Rows aren't deleted on completion — they're history. The
/// next task that wants the session just runs the lock query and sees
/// "free" once every row is on a Done task.
model BrowserSession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Gateway-side session name (`preferences.browser.sessions[<name>]`) — what
  /// the agent asked for. Display + audit only; not the lock key.
  sessionName String

  /// Profile the session resolves to on the gateway. Lock is keyed on this:
  /// only one active task may hold a given `(gatewayId, profileName)` pair,
  /// because each profile maps to a single Chromium `userDataDir` which
  /// Chromium itself locks via SingletonLock.
  profileName String

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String

  gateway   Gateway @relation(fields: [gatewayId], references: [id], onDelete: Cascade)
  gatewayId String

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  @@index([taskId])
  @@index([workspaceId])
  @@index([gatewayId, sessionName])
  @@index([gatewayId, profileName])
}

enum ContactStatus {
  Researching
  Active
  Hidden
}

enum ContactSource {
  Auto
  Manual
}

model Contact {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  userId      String

  entityUuid String?

  name     String
  category String?

  emails   String[] @default([])
  phones   String[] @default([])
  company  String?
  role     String?
  location String?
  handles  String[] @default([])

  headline          String?
  description       String?
  descriptionEdited Boolean   @default(false)
  editedAt          DateTime?

  status ContactStatus @default(Researching)
  source ContactSource @default(Auto)

  lastMemoryAt     DateTime?
  lastSummarizedAt DateTime?

  avatarUrl String?

  @@unique([workspaceId, entityUuid])
  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([userId])
}
