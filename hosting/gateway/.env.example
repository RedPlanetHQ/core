# ─────────────────────────────────────────────────────────────────────────
# CoreBrain Gateway — example environment file.
#
# Copy to `.env` (alongside docker-compose.yaml) and fill in the values:
#     cp .env.example .env
#     docker compose up -d
#
# Anything left blank just stays unset; the gateway falls back to safe
# defaults or skips the corresponding feature.
# ─────────────────────────────────────────────────────────────────────────

# ── CORE webapp wiring ──────────────────────────────────────────────────
# Where this gateway reports back to.
COREBRAIN_API_URL=https://app.getcore.me
# Personal access token from CORE → Settings → Tokens.
COREBRAIN_API_KEY=

# ── Gateway identity ────────────────────────────────────────────────────
COREBRAIN_GATEWAY_NAME=cloud-gateway
COREBRAIN_GATEWAY_DESCRIPTION=Cloud-hosted CoreBrain gateway

# Pinning a security key is optional. If left blank, the gateway generates
# one on first boot and prints it to `docker compose logs` — copy from there
# and paste (with the gateway URL) into the webapp's "Register gateway"
# dialog. Re-set this here once you've got the value, so future restarts
# don't re-prompt.
COREBRAIN_GATEWAY_SECURITY_KEY=

# ── Coding agent auth (env-only — no webapp UI for tokens) ──────────────
# claude-code: long-lived token from `claude setup-token` (run on a
# laptop where you've authenticated with `claude login`).
CLAUDE_CODE_OAUTH_TOKEN=
# codex-cli: standard OpenAI API key.
OPENAI_API_KEY=

# ── Git ─────────────────────────────────────────────────────────────────
# Personal access token used by `git clone` for private repos and by the
# gateway to derive author identity (name + email) via the GitHub API.
# Scopes: `repo` (or fine-grained "Contents: Read & write"), plus
# `read:user` (and optionally `user:email`) for identity discovery.
GITHUB_TOKEN=

# ── Container ───────────────────────────────────────────────────────────
# Image tag to deploy. Override during local dev with `:dev` or `:edge`.
COREBRAIN_GATEWAY_IMAGE=redplanethq/corebrain-gateway:latest
# Public-facing port mapping. Adjust if 7787 is taken.
COREBRAIN_GATEWAY_HTTP_PORT=7787
# Docker restart policy.
RESTART_POLICY=unless-stopped
